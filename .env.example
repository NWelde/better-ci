# BetterCI environment configuration
# Copy this file to .env and fill in values before running the cloud stack.
#
# Usage (cloud API):
#   cp .env.example .env
#   docker-compose up
#
# Usage (local runner):
#   No environment variables are required for `betterci run`.
#   Only set secrets that your workflow jobs declare in job(secrets=[...]).

# ---------------------------------------------------------------------------
# Cloud API — required for the cloud/docker-compose stack
# ---------------------------------------------------------------------------

# PostgreSQL connection string (asyncpg driver)
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<db>
DATABASE_URL=postgresql+asyncpg://betterci:betterci@localhost:5432/betterci

# Redis connection string
REDIS_URL=redis://localhost:6379/0

# Name of the Redis queue used to distribute jobs to agents
QUEUE_NAME=betterci:queue

# How long (in seconds) an agent has to complete a job before its lease expires
# and the job is automatically re-queued for another agent. Default: 600.
LEASE_SECONDS=600

# ---------------------------------------------------------------------------
# Authentication (optional but strongly recommended for production)
# ---------------------------------------------------------------------------

# When set, the cloud API requires the header X-API-Key: <value> on all
# mutating requests (POST /runs, POST /leases/*, POST /leases/*/complete).
# Leave empty to disable authentication (useful for local/dev setups).
#
# Generate a strong key:
#   python -c "import secrets; print(secrets.token_hex(32))"
BETTERCI_API_KEY=

# ---------------------------------------------------------------------------
# Agent (set on machines running `betterci agent`)
# ---------------------------------------------------------------------------

# URL of the cloud API the agent polls
BETTERCI_API_URL=http://localhost:8000

# Unique name for this agent instance (defaults to hostname if not set)
# BETTERCI_AGENT_ID=worker-1

# ---------------------------------------------------------------------------
# Workflow secrets (set per-project, never commit to git)
# ---------------------------------------------------------------------------
# These are examples of env vars your workflow jobs might declare via
# job(secrets=["MY_SECRET", ...]).
#
# BetterCI validates that all declared secrets are present in the environment
# BEFORE any steps run — so you get a clear error immediately instead of
# failing hours into a pipeline run.
#
# DATABASE_URL=postgres://user:pass@host/db
# API_KEY=your-api-key-here
# DOCKER_REGISTRY_TOKEN=your-token-here
